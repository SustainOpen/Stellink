{
  "name": "stellink",
  "version": "0.1.0",
  "private": true,
  "description": "Stellink — shareable payment links on Stellar. One-time, recurring, or escrow-protected XLM and USDC.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SustainOpen/Stellink"
  },
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm --workspace @stellink/frontend run dev",
    "build": "npm --workspace @stellink/frontend run build",
    "lint": "npm --workspace @stellink/frontend run lint",
    "test": "npm --workspace @stellink/frontend run test",
    "test:watch": "npm --workspace @stellink/frontend run test:watch",
    "preview": "npm --workspace @stellink/frontend run preview",
    "pb:setup": "bash scripts/pocketbase-setup.sh",
    "pb:up": "docker compose up -d pocketbase",
    "pb:down": "docker compose down",
    "contracts:build": "cd contracts && cargo build --release --target wasm32-unknown-unknown",
    "contracts:test": "cd contracts && cargo test"
  }
}
