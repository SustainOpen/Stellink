# PayBeam frontend — environment configuration
#
# Copy this file to `.env.local` and fill in the values you need. All
# variables are optional — the app degrades gracefully without them.

# ────────────────────────────────────────────────────────────────
# Network selection
# ────────────────────────────────────────────────────────────────
# "testnet" (default) or "public" (Stellar mainnet).
VITE_STELLAR_NETWORK=testnet

# ────────────────────────────────────────────────────────────────
# PocketBase (optional)
# ────────────────────────────────────────────────────────────────
# URL of a running PocketBase instance. Without this, the app stores links
# in localStorage only and they're scoped to the device that created them.
#
# Spin up a local PocketBase in seconds:
#   1. Download the binary from https://pocketbase.io/docs/
#   2. cd .. && ./scripts/pocketbase-setup.sh
#   3. Set this to http://127.0.0.1:8090
VITE_POCKETBASE_URL=

# ────────────────────────────────────────────────────────────────
# Soroban escrow registry (optional)
# ────────────────────────────────────────────────────────────────
# Contract id returned by `soroban contract deploy`. Empty = registry calls
# are skipped, but native claimable-balance escrow still works.
VITE_PAYBEAM_ESCROW_CONTRACT_ID=
